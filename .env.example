# Telegram Bot 配置
BOT_TOKEN=your_telegram_bot_token_here

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/selfcontrol
MONGODB_TEST_URI=mongodb://localhost:27017/selfcontrol_test

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 应用配置
NODE_ENV=development
PORT=3000

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 安全配置
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# 功能开关
ENABLE_PROGRESS_REMINDERS=true
ENABLE_WEEKLY_REPORTS=true
ENABLE_RESERVATION_SYSTEM=true

# 神圣座位原理配置
SACRED_SEAT_STRICT_MODE=true
AUTO_CHAIN_BREAK_ON_FAILURE=true

# 线性时延原理配置
DEFAULT_RESERVATION_DELAY=900  # 15分钟（秒）
RESERVATION_REMINDER_ENABLED=true

# 性能配置
MAX_CONCURRENT_TASKS=100
QUEUE_CONCURRENCY=5
DATABASE_POOL_SIZE=10

# 监控配置
METRICS_ENABLED=false
HEALTH_CHECK_INTERVAL=30000

# 开发配置
DEBUG_MODE=false
MOCK_TELEGRAM_API=false