{
  "name": "telegram-self-control-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "基于自控力理论的Telegram机器人",
  "main": "dist/src/app.js",
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "start": "node dist/src/app.js",
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "lint": "eslint src config tests vitest.config.ts --ext .ts",
    "lint:fix": "eslint src config tests vitest.config.ts --ext .ts --fix",
    "format": "prettier --write 'src/**/*.{js,ts}' 'config/**/*.{js,ts}' 'tests/**/*.{js,ts}'",
    "format:check": "prettier --check 'src/**/*.{js,ts}' 'config/**/*.{js,ts}' 'tests/**/*.{js,ts}'",
    "setup": "node scripts/setup.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "docker:build": "docker build -t telegram-self-control-bot .",
    "docker:dev": "docker-compose up -d",
    "docker:prod": "docker-compose -f docker/docker-compose.prod.yml up -d",
    "docker:stop": "docker-compose down",
    "validate": "npm run lint && npm run typecheck && npm run build && npm test",
    "pre-commit": "npm run lint:fix && npm run format && npm test",
    "pm2:start": "bash scripts/pm2-start.sh",
    "pm2:stop": "pm2 stop telegram-self-control-bot",
    "pm2:restart": "pm2 restart telegram-self-control-bot",
    "pm2:reload": "pm2 reload telegram-self-control-bot",
    "pm2:delete": "pm2 delete telegram-self-control-bot",
    "pm2:logs": "pm2 logs telegram-self-control-bot",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status telegram-self-control-bot",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "dependencies": {
    "bull": "^4.11.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "lodash": "^4.17.21",
    "moment-timezone": "^0.5.43",
    "mongoose": "^7.5.0",
    "node-telegram-bot-api": "^0.61.0",
    "redis": "^4.6.7",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.45.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "telegram",
    "bot",
    "self-control",
    "productivity",
    "task-management"
  ],
  "author": "Telegram Self Control Bot",
  "license": "MIT"
}
